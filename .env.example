# Embedding Provider Configuration
EMBEDDING_PROVIDER=openai  # or sentence-transformers
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI Configuration (required for OpenAI provider)
OPENAI_API_KEY=your-openai-api-key

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional
COLLECTION_NAME=mcp_memory

# Search Configuration
DEFAULT_LIMIT=10
SCORE_THRESHOLD=0.0

# MCP namespace (default prefixes tools: qdrant_store, qdrant_find, ...)
NAMESPACE=qdrant

# HTTP server (Cloud Run / Docker)
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000
FASTMCP_TRANSPORT=streamable-http

# Optional bearer token for HTTP transport (required in Authorization header)
# AUTH_BEARER_TOKEN=

# Sentence Transformers Configuration (optional)
DEVICE=cpu  # or cuda, mps, etc.